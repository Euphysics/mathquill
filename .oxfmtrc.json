{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "none",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": [
    "build",
    "src/intro.js",
    "src/outro.js",
    "test/support/jquery-1.5.2.js"
  ]
}
